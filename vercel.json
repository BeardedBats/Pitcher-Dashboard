{
  "buildCommand": "cd frontend && npm install && npm run build",
  "outputDirectory": "frontend/build",
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/index.py" }
  ],
  "crons": [
    { "path": "/api/cron/warmup", "schedule": "0 0-4,17-23 * * *" },
    { "path": "/api/cron/warmup-daily", "schedule": "30 9 * * *" },
    { "path": "/api/cron/warmup-daily-players", "schedule": "40 9 * * *" },
    { "path": "/api/cron/warmup-daily-cards", "schedule": "50 9 * * *" }
  ]
}

{
  "builds": [
    {
      "src": "index.py",
      "use": "@vercel/python"
    },
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "build"
      }
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "index.py" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ],
  "crons": [
    { "path": "/api/cron/warmup", "schedule": "0 10 * * *" },
    { "path": "/api/cron/warmup", "schedule": "0 22 * * *" },
    { "path": "/api/cron/warmup", "schedule": "0 3 * * *" }
  ]
}
